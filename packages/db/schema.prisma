generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Portal Core Models
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  workspaceMembers WorkspaceMember[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]        @relation("UserAuditLogs")

  // PM Module opposite relations
  assignedIssues PmIssue[]   @relation("IssueAssignee")
  createdIssues  PmIssue[]   @relation("IssueCreator")
  pmComments     PmComment[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  modules   WorkspaceModule[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]

  // PM Module opposite relations
  pmProjects PmProject[]
  pmLabels   PmLabel[]
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceModule {
  id          String   @id @default(cuid())
  workspaceId String
  moduleId    String // e.g., "pm", "traces"
  enabled     Boolean  @default(false)
  config      Json? // Optional JSON config for module specific settings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleId])
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique // Hashed/Encrypted key
  name        String
  workspaceId String
  userId      String? // Optional: if key is tied to a specific user
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String // e.g., "module.enabled", "user.invited"
  entityType  String // e.g., "WorkspaceModule"
  entityId    String?
  details     Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?      @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
}

// -----------------------------------------------------------------------------
// Module: PM Models
// -----------------------------------------------------------------------------

model PmProject {
  id          String   @id @default(cuid())
  workspaceId String
  key         String   @unique // e.g., FPM
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues    PmIssue[]
  sprints   PmSprint[]
}

enum PmIssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELED
}

enum PmIssuePriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model PmIssue {
  id          String          @id @default(cuid())
  projectId   String
  key         String          @unique // e.g., FPM-123
  title       String
  description String?
  status      PmIssueStatus   @default(TODO)
  priority    PmIssuePriority @default(NONE)
  storyPoints Int?

  assigneeId String?
  creatorId  String
  sprintId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?     @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User      @relation("IssueCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  sprint   PmSprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  comments PmComment[]
  labels   PmLabel[]   @relation("IssueLabels")
}

model PmSprint {
  id        String    @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("PLANNED") // PLANNED, ACTIVE, COMPLETED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project PmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  PmIssue[]
}

model PmComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  PmIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PmLabel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#808080")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues    PmIssue[] @relation("IssueLabels")
}
